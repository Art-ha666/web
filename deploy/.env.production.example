# =============================================================================
# AKH Solutions — PRODUCTION environment (Vultr VPS behind Cloudflare)
# Target: single small Vultr VPS, app at https://akhsolutions.net
#
# HOW TO USE
#   1. Copy this file to `.env` on the server (NEVER commit the real .env).
#   2. Generate APP_KEY once:  php artisan key:generate --show
#      (or `docker compose run --rm app php artisan key:generate --show`)
#      then paste the value into APP_KEY below. Do NOT commit it.
#   3. Fill in every <CHANGE_ME> value (DB password, Redis password, mail, AI keys).
#   4. Keep this file mode 600 and owned by the deploy user.
#
# All secrets here are PLACEHOLDERS. Do not store real credentials in git.
# =============================================================================

# --- Core application ---------------------------------------------------------
APP_NAME="AKH Solutions"
APP_ENV=production
# APP_KEY MUST be generated, NOT committed. Leave blank in git; set on the server.
APP_KEY=
APP_DEBUG=false
APP_URL=https://akhsolutions.net

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# Cost vs. brute-force resistance trade-off; 12 is a fine default.
BCRYPT_ROUNDS=12

# --- Logging ------------------------------------------------------------------
# stderr so Docker/journald captures it; keep production noise to warning+.
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# --- Database (MySQL 8 service) ----------------------------------------------
# DB_HOST must match the docker-compose service name (e.g. "mysql"), or the
# socket/host of a system MySQL on the VPS. Do NOT use root in production.
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=akh_solutions
DB_USERNAME=akh
DB_PASSWORD=<CHANGE_ME_STRONG_DB_PASSWORD>
# Only needed if MySQL enforces TLS (managed DB). For same-host docker, leave unset.
# MYSQL_ATTR_SSL_CA=

# --- Sessions -----------------------------------------------------------------
# Redis-backed sessions (fast, shared across php-fpm + queue workers).
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Scope the cookie to the apex/host. Leave as the bare host so it is not shared
# with other akhsolutions.net subdomains.
SESSION_DOMAIN=akhsolutions.net
# CRITICAL behind Cloudflare/HTTPS: only send the session cookie over HTTPS.
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# --- Cache --------------------------------------------------------------------
CACHE_STORE=redis
# CACHE_PREFIX=akh-solutions-cache-

# --- Queue --------------------------------------------------------------------
# Redis queue; the supervisord `queue` worker (see docker/production) drains it.
QUEUE_CONNECTION=redis

# --- Broadcast / Filesystem ---------------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- Redis --------------------------------------------------------------------
# REDIS_HOST must match the docker-compose service name (e.g. "redis").
# Set a password (requirepass) even on a private Docker network as defence-in-depth.
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=<CHANGE_ME_STRONG_REDIS_PASSWORD>
REDIS_PORT=6379
# Separate logical DBs keep cache/session/queue from colliding:
REDIS_DB=0
REDIS_CACHE_DB=1

# --- Mail (placeholder — wire to a real SMTP/relay before sending) ------------
# Defaults to "log" so no mail is sent until real credentials are provided.
# Lead-notification mails go through the queue worker, so configure this when ready.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=<CHANGE_ME_SMTP_HOST>
MAIL_PORT=587
MAIL_USERNAME=<CHANGE_ME_SMTP_USERNAME>
MAIL_PASSWORD=<CHANGE_ME_SMTP_PASSWORD>
MAIL_FROM_ADDRESS="hello@akhsolutions.net"
MAIL_FROM_NAME="${APP_NAME}"

# --- AWS / S3 (unused on this VPS; leave blank) -------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Frontend (Vite) ----------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"

# --- AI blog writer (optional) ------------------------------------------------
# Leave blank to use the offline template generator. Keys can also be managed
# per-provider in Admin -> AI Writer. Do NOT commit real keys.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# --- Migrations on boot -------------------------------------------------------
# Keep "false": migrations run as an explicit one-off step in the deploy pipeline
# (docker compose run --rm app php artisan migrate --force), NOT on every boot —
# this avoids the app + queue containers racing to migrate. The compose file also
# pins this to "false" for the long-running app service.
RUN_MIGRATIONS=false
